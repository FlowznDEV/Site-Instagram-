{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Represents a potential client (lead) captured through the commercial form.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the lead" },
        "name": { "type": "string", "description": "Name of the lead contact" },
        "company": { "type": "string", "description": "Name of the lead's company" },
        "whatsapp": { "type": "string", "description": "WhatsApp contact number" },
        "instagram": { "type": "string", "description": "Instagram handle" },
        "segment": { "type": "string", "description": "Business segment/niche" },
        "challenges": {
          "type": "array",
          "description": "List of business challenges checked by the lead"
        },
        "source": { "type": "string", "description": "Source of origin of the lead" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "diagnostic": {
          "type": "object",
          "description": "AI-generated diagnostic data"
        }
      },
      "required": ["id", "name", "company", "whatsapp", "createdAt"]
    },
    "Config": {
      "title": "Config",
      "description": "Application wide configuration properties like admin security settings.",
      "type": "object",
      "properties": {
        "adminPassword": { "type": "string", "description": "Admin console password hash or PIN" }
      },
      "required": ["adminPassword"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of all submitted leads"
    },
    "/config/{configId}": {
      "schema": "Config",
      "description": "Global or environment configuration values"
    }
  }
}
